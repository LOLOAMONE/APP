# Chemin de la base SQLite. En local, un simple fichier suffit.
# En production (Railway/Render), pointez ce chemin vers le disque persistant monté
# (ex: "file:/data/prod.db") pour ne jamais perdre les données entre les déploiements.
DATABASE_URL="file:./dev.db"

# Clé secrète utilisée pour signer les sessions de connexion.
# Générez-en une nouvelle en production avec : openssl rand -base64 32
SESSION_SECRET="changez-moi-en-une-longue-chaine-aleatoire"

# Identifiants du compte direction (ADMIN du restaurant "Amoné Nice") créé automatiquement
# au premier démarrage (seed). Changez le mot de passe après la première connexion.
ADMIN_USERNAME="direction"
ADMIN_PASSWORD="changeme123"

# Optionnel — compte SUPER_ADMIN (maison mère, accès à tous les restaurants du réseau).
# Laissez vide pour ne pas en créer. Un SUPER_ADMIN existant peut ensuite en promouvoir
# d'autres depuis l'application ; ce bootstrap ne doit servir qu'au tout premier compte.
SUPER_ADMIN_USERNAME=""
SUPER_ADMIN_PASSWORD=""
