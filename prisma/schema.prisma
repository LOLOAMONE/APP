// Schéma de la base de données du gestionnaire de restaurant.
// Note: le connecteur SQLite ne supporte pas les enums natifs Prisma,
// les champs "rôle/type/statut/module" sont donc des String validés côté application (voir src/lib/validation.ts).
//
// Architecture multi-restaurants :
// - Restaurant est l'unité d'isolation des données métier (chaque table métier a un restaurantId direct
//   quand elle est listée/créée indépendamment ; les tables enfants/jonction héritent du scope de leur parent).
// - User est une identité globale. Son rattachement à un ou plusieurs restaurants passe par UserRestaurant
//   (rôle local ADMIN/EMPLOYEE) et/ou ModulePermission (accès à un module précis, sur un restaurant
//   donné ou à portée globale via restaurantId = null).
// - User.isSuperAdmin outrepasse tout le reste, sans avoir besoin d'aucune ligne UserRestaurant/ModulePermission.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  status    String   @default("ACTIVE") // "ACTIVE" | "SUSPENDED" | "ARCHIVED"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships          UserRestaurant[]
  modulePermissions    ModulePermission[]
  employees            Employee[]
  ingredients          Ingredient[]
  measureUnits         MeasureUnit[]
  products             Product[]
  menus                Menu[]
  suppliers            Supplier[]
  packagingUnits       PackagingUnit[]
  crmCompanies         CrmCompany[]
  crmContacts          CrmContact[]
  crmOpportunities     CrmOpportunity[]
  tickets              Ticket[]
  channels             Channel[]
  customerVisits       CustomerVisit[]
  loyaltyLedgerEntries LoyaltyLedgerEntry[]
  campaigns            Campaign[]
  campaignTargets      CampaignRestaurant[]
  couponRedemptions    CouponRedemption[]
  editorialPosts       EditorialPost[]
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  isSuperAdmin Boolean  @default(false) // outrepasse tout, indépendant de tout restaurant
  createdAt    DateTime @default(now())

  memberships            UserRestaurant[]
  modulePermissions      ModulePermission[]
  employee               Employee?
  tickets                Ticket[]           @relation("TicketAuthor")
  ticketMessages         TicketMessage[]    @relation("TicketMessageSender")
  channelMessages        ChannelMessage[]   @relation("ChannelMessageSender")
  campaignsCreated       Campaign[]         @relation("CampaignCreator")
  editorialPostsCreated  EditorialPost[]    @relation("EditorialPostAuthor")
  editorialPostsReviewed EditorialPost[]    @relation("EditorialPostReviewer")
}

// Rattachement d'un utilisateur à un restaurant, avec son rôle LOCAL à ce restaurant.
// Un ADMIN local a accès à tous les modules de ce restaurant sans ligne ModulePermission dédiée.
model UserRestaurant {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  role         String // "ADMIN" | "EMPLOYEE"
  createdAt    DateTime   @default(now())

  @@unique([userId, restaurantId])
}

// Accès d'un utilisateur à un module précis ("marges" | "mercuriale" | "crm" | futurs modules
// transverses "marketing" | "ticketing" | ...), soit sur UN restaurant, soit à portée globale
// (restaurantId = null) pour les comptes transverses réseau.
//
// Note SQLite : la contrainte @@unique ci-dessous ne bloque PAS les doublons quand restaurantId
// est NULL (NULL n'est jamais égal à NULL en SQL). L'unicité des permissions à portée globale
// (restaurantId null) doit être vérifiée côté application (recherche avant insertion).
model ModulePermission {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  module       String
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())

  @@unique([userId, module, restaurantId])
}

model Employee {
  id               String                  @id @default(cuid())
  restaurantId     String
  restaurant       Restaurant              @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name             String
  position         String
  hourlyRate       Float?
  userId           String?                 @unique
  user             User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  shifts           Shift[]
  absences         Absence[]
  scheduleTemplate ScheduleTemplateEntry[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
}

// Créneau récurrent du planning de base d'un employé (ex: tous les lundis 9h-17h).
model ScheduleTemplateEntry {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  dayOfWeek  Int // 0 = lundi ... 6 = dimanche
  startTime  String // "HH:mm"
  endTime    String // "HH:mm"
}

model Ingredient {
  id           String                   @id @default(cuid())
  restaurantId String
  restaurant   Restaurant               @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  unit         String // "kg" | "L" | "piece" | unité personnalisée (voir MeasureUnit)
  price        Float // prix d'achat actuel, dans l'unité ci-dessus
  supplier     String?
  category     String? // sous-catégorie libre (ex: "Viandes", "Emballages")
  order        Int                      @default(0) // ordre d'affichage, modifiable par glisser-déposer
  priceHistory IngredientPriceHistory[]
  productLinks ProductIngredient[]
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
}

// Liste réutilisable d'unités personnalisées (en plus de kg/L/pièce), utilisée à la fois comme
// unité d'achat d'un ingrédient et comme unité de quantité en recette pour cet ingrédient.
model MeasureUnit {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  label        String

  @@unique([restaurantId, label])
}

model IngredientPriceHistory {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  price        Float
  recordedAt   DateTime   @default(now())
}

model Product {
  id            String              @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name          String
  category      String              @default("Autre")
  priceOnSite   Float // prix de vente TTC sur place
  priceTakeaway Float // prix de vente TTC à emporter
  order         Int                 @default(0) // ordre d'affichage au sein de sa catégorie, modifiable par glisser-déposer
  ingredients   ProductIngredient[]
  menuLinks     MenuItem[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model Menu {
  id            String     @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name          String
  priceOnSite   Float // prix de vente TTC sur place
  priceTakeaway Float // prix de vente TTC à emporter
  order         Int        @default(0) // ordre d'affichage, modifiable par glisser-déposer
  items         MenuItem[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model MenuItem {
  id        String  @id @default(cuid())
  menuId    String
  menu      Menu    @relation(fields: [menuId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int     @default(1)
}

model ProductIngredient {
  id           String     @id @default(cuid())
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
  quantity     Float // quantité dans quantityUnit
  quantityUnit String // "g" | "kg" | "mL" | "L" | "piece"
  channel      String     @default("BOTH") // "BOTH" | "SUR_PLACE" | "EMPORTER" — permet un coût de revient différent selon le mode de vente (emballages différents)
}

model Supplier {
  id            String         @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name          String
  category      String? // catégorie libre regroupant les onglets fournisseurs (ex: "Boissons", "Mobilier")
  order         Int            @default(0) // ordre d'affichage des sous-onglets, modifiable par glisser-déposer
  orderSchedule String? // jour/délai de commande et de livraison
  minimumOrder  String? // franco / minimum de commande
  email         String?
  phone         String?
  clientCode    String?
  notes         String? // toute autre information libre
  items         SupplierItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model SupplierItem {
  id            String    @id @default(cuid())
  supplierId    String
  supplier      Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  order         Int       @default(0) // ordre d'affichage dans le tableau, modifiable par glisser-déposer
  reference     String?
  designation   String
  category      String? // sous-catégorie libre au sein du fournisseur (ex: "Boissons", "Emballages")
  packaging     String? // conditionnement
  orderQuantity Float     @default(0) // quantité à commander
  unitPriceHT   Float?
  casePriceHT   Float? // prix carton / colis / lot HT
  orderedAt     DateTime? // date à laquelle l'article a été commandé (vide = pas encore commandé)
  receivedAt    DateTime? // date à laquelle l'article a été reçu (vide = pas encore reçu)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Liste réutilisable de conditionnements (ex: "Carton de 12", "Lot de 6") proposée dans le formulaire article.
model PackagingUnit {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  label        String

  @@unique([restaurantId, label])
}

model Shift {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       String // "YYYY-MM-DD"
  startTime  String // "HH:mm"
  endTime    String // "HH:mm"
  createdAt  DateTime @default(now())
}

model Absence {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startDate  String // "YYYY-MM-DD"
  endDate    String // "YYYY-MM-DD"
  type       String // "CONGE_PAYE" | "MALADIE" | "AUTRE"
  status     String   @default("APPROVED") // "PENDING" | "APPROVED" | "REJECTED"
  note       String?
  createdAt  DateTime @default(now())
}

// CRM pour les clients entreprises / événements (séminaires, groupes, privatisations) —
// distinct des clients du quotidien qui ne sont pas suivis nommément.
model CrmCompany {
  id            String           @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name          String
  sector        String? // secteur d'activité
  address       String?
  phone         String?
  email         String?
  notes         String?
  contacts      CrmContact[]
  opportunities CrmOpportunity[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model CrmContact {
  id            String           @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  companyId     String?
  company       CrmCompany?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  name          String
  role          String? // fonction dans l'entreprise
  phone         String?
  email         String?
  notes         String?
  opportunities CrmOpportunity[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model CrmOpportunity {
  id           String      @id @default(cuid())
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  title        String // ex: "Séminaire annuel Société X"
  companyId    String?
  company      CrmCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId    String?
  contact      CrmContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  stage        String      @default("PROSPECT") // "PROSPECT" | "DEVIS_ENVOYE" | "CONFIRME" | "REALISE" | "PERDU"
  order        Int         @default(0) // ordre d'affichage au sein de sa colonne (kanban), modifiable par glisser-déposer
  eventDate    String? // "YYYY-MM-DD"
  guestCount   Int?
  amount       Float? // montant estimé / devis
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

// Module TICKETING — demandes d'un restaurant vers la maison mère (remplace l'email).
// Accès local : tout membre du restaurant (UserRestaurant), pas de permission dédiée.
// Accès transverse "maison mère" : User.isSuperAdmin ou ModulePermission(module: "ticketing", restaurantId: null),
// réutilisant le même mécanisme générique que les autres modules — voir requireTicketReach() dans src/lib/auth.ts.
model Ticket {
  id              String          @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  subject         String
  description     String // contenu initial, distinct du fil de discussion (TicketMessage)
  status          String          @default("OPEN") // "OPEN" | "IN_PROGRESS" | "RESOLVED" | "CLOSED"
  category        String? // libre
  createdByUserId String?
  createdBy       User?           @relation("TicketAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)
  messages        TicketMessage[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt // "touché" à chaque nouveau message -> tri par activité récente
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId  String?
  sender    User?    @relation("TicketMessageSender", fields: [senderId], references: [id], onDelete: SetNull)
  content   String
  createdAt DateTime @default(now())
}

// Canaux internes façon Slack, INDÉPENDANTS des tickets — communication entre employés d'UN
// même restaurant uniquement (pas entre restaurants, pas avec la maison mère par défaut).
model Channel {
  id           String           @id @default(cuid())
  restaurantId String
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  isDefault    Boolean          @default(false) // canal "Général" créé à la création du restaurant, non supprimable
  createdAt    DateTime         @default(now())
  messages     ChannelMessage[]

  @@unique([restaurantId, name])
}

model ChannelMessage {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderId  String?
  sender    User?    @relation("ChannelMessageSender", fields: [senderId], references: [id], onDelete: SetNull)
  content   String
  createdAt DateTime @default(now())
}

// Module MARKETING — CRM fidélité unifié réseau + campagnes national/local + calendrier éditorial
// partagé. Réutilise ModulePermission("marketing") exactement comme "ticketing" ; contrairement à
// Tickets/Canaux (ouverts à tout membre), l'accès local est réservé à l'ADMIN du restaurant ou à
// une permission "marketing" locale explicite (voir activeCanAccessMarketing) — données clients/
// budget plus sensibles, même traitement que Marges/Mercuriale/Crm.

// Client unifié réseau — existe une seule fois, pas un profil par restaurant. Distinct de
// CrmCompany/CrmContact (CRM B2B événements/séminaires, section "Clients" existante).
model Customer {
  id            String   @id @default(cuid())
  firstName     String?
  lastName      String?
  email         String?  @unique
  phone         String?  @unique
  loyaltyPoints Int      @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  visits            CustomerVisit[]
  loyaltyLedger     LoyaltyLedgerEntry[]
  couponRedemptions CouponRedemption[]
}

model CustomerVisit {
  id           String     @id @default(cuid())
  customerId   String
  customer     Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  amount       Float? // montant dépensé, si connu
  source       String     @default("MANUAL") // "MANUAL" | "POPINA" (lien futur, non bloquant)
  visitedAt    DateTime   @default(now())
}

// Historique des points (gain/utilisation) — permet un point gagné dans un restaurant et
// utilisé dans un autre, traçable, plutôt qu'un simple compteur.
model LoyaltyLedgerEntry {
  id           String      @id @default(cuid())
  customerId   String
  customer     Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  restaurantId String? // restaurant où l'évènement a eu lieu, null si ajustement réseau
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  points       Int // positif = gain, négatif = utilisation
  reason       String // "VISIT" | "REDEMPTION" | "MANUAL_ADJUSTMENT"
  createdAt    DateTime    @default(now())
}

// Campagne NATIONALE (restaurantId null, créée par la maison mère, non modifiable par les
// franchisés) ou LOCALE (restaurantId requis, créée par un gérant, son propre budget).
model Campaign {
  id              String      @id @default(cuid())
  scope           String // "NATIONAL" | "LOCAL"
  restaurantId    String? // requis si LOCAL, null si NATIONAL
  restaurant      Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  status          String      @default("DRAFT") // "DRAFT" | "ACTIVE" | "PAUSED" | "ENDED"
  startDate       DateTime?
  endDate         DateTime?
  budget          Float?
  allRestaurants  Boolean     @default(true) // si NATIONAL : true = tous, false = voir CampaignRestaurant
  createdByUserId String?
  createdBy       User?       @relation("CampaignCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  targets CampaignRestaurant[]
  coupons Coupon[]
}

// Sélection de restaurants ciblés par une campagne NATIONALE non diffusée à tous.
model CampaignRestaurant {
  id           String     @id @default(cuid())
  campaignId   String
  campaign     Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([campaignId, restaurantId])
}

model Coupon {
  id             String    @id @default(cuid())
  campaignId     String
  campaign       Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  code           String    @unique
  discountType   String // "PERCENT" | "FIXED_AMOUNT" | "FREE_ITEM"
  discountValue  Float?
  maxRedemptions Int?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  redemptions CouponRedemption[]
}

model CouponRedemption {
  id           String     @id @default(cuid())
  couponId     String
  coupon       Coupon     @relation(fields: [couponId], references: [id], onDelete: Cascade)
  customerId   String?
  customer     Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  amount       Float? // montant de la remise réellement appliquée
  source       String     @default("MANUAL") // lien Popina futur, non bloquant
  redeemedAt   DateTime   @default(now())
}

// Calendrier éditorial partagé — planification/visualisation uniquement : aucune connexion aux
// réseaux sociaux, aucune publication automatique. mediaUrl est un simple lien externe
// (fichier déjà hébergé par l'utilisateur, ex. OneDrive/Drive) — l'app n'héberge aucun média.
model EditorialPost {
  id                  String      @id @default(cuid())
  restaurantId        String? // null = national (maison mère)
  restaurant          Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  title               String
  caption             String
  mediaUrl            String? // lien externe, non hébergé par l'app
  platforms           String // JSON stringifié, ex. ["INSTAGRAM","FACEBOOK","GOOGLE"] — indicatif, aucune connexion réelle (SQLite ne supporte pas le type Json natif de Prisma)
  scheduledAt         DateTime
  status              String      @default("DRAFT")
  // "DRAFT" | "PENDING_VALIDATION" | "VALIDATED" | "PUBLISHED" | "REJECTED"
  validationRequested Boolean     @default(false)
  reviewedByUserId    String?
  reviewedBy          User?       @relation("EditorialPostReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reviewComment       String?
  publishedAt         DateTime? // renseigné manuellement quand quelqu'un marque le post comme publié
  createdByUserId     String?
  createdBy           User?       @relation("EditorialPostAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}
